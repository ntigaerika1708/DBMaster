# /etc/vaultdb-agent.env — configuração do VaultDB Agent
# Copie para /etc/vaultdb-agent.env e ajuste. Proteja: chmod 600.

VAULTDB_DIRECTOR=http://director.interno:8000
VAULTDB_USER=admin
VAULTDB_PASS=troque-esta-senha
# Em alternativa a user/pass, use um JWT já obtido:
# VAULTDB_TOKEN=eyJhbGciOi...

VAULTDB_CONN=coloque-o-connection_id
VAULTDB_DB=meu_banco
VAULTDB_TYPE=full
VAULTDB_COMPRESSION=zstd
# VAULTDB_TABLES=clientes,faturas   # vazio = todas
VAULTDB_INTERVAL=24h
