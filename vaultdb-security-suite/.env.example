# VaultDB Security Suite — Configurações de Ambiente
# Copie para .env e preencha os valores
#
# Layout do repo: a raiz e a pasta vaultdb-security-suite/ podem espelhar o mesmo código — alinhe após editar.
# docker compose: ./backups e ./data dependem da pasta de onde corre o comando.

# ── Segurança ──────────────────────────────────────────────────────
SECRET_KEY=vaultdb-MUDE-ESTA-CHAVE-EM-PRODUCAO-$(openssl rand -hex 32)

# ── Redis / Celery ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Portas publicadas (Docker Compose) ───────────────────────────
# Raiz "files (5)": predefinições no compose — Director 8001, Redis 6380, Prometheus 9091 (stack paralelo).
# Pasta vaultdb-security-suite/: predefinições 8000, 6379, 9090.
# Para forçar: HOST_PORT_DIRECTOR=8000
# HOST_PORT_REDIS=6379
# HOST_PORT_PROMETHEUS=9090

# ── mysqldump (TLS) ───────────────────────────────────────────────
# DISABLED = desliga TLS no .cnf (ssl=0) + tentativas --skip-ssl (MariaDB 11 no container)
# DEFAULT = sem ajuste TLS automático
# MYSQLDUMP_EXTRA_ARGS=--ssl-mode=VERIFY_CA --ssl-ca=/caminho/ca.pem
MYSQLDUMP_SSL_MODE=DISABLED

# ── E-mail (Workflow de aprovação de restore) ──────────────────────
# Com SMTP_HOST + SMTP_USER (+ SMTP_PASS se necessário) o VaultDB envia o link de aprovação.
# Sem SMTP, aprove no painel (Restaurar → Aprovar) ou abra o URL /api/restore/confirm?token=... no navegador.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua-senha-app

# ── Telegram Alerts ────────────────────────────────────────────────
# BotFather: /newbot → copie o token
TELEGRAM_TOKEN=
# ID do grupo ou chat (use @userinfobot para descobrir)
TELEGRAM_CHAT_ID=

# ── Proxmox (Sandbox LXC de validação automática de restore) ───────
# Também configurável pelo painel (Configurações). Use um API Token dedicado.
PROXMOX_HOST=proxmox.local
PROXMOX_NODE=pve
PROXMOX_TOKEN_ID=vaultdb@pve!sandbox
PROXMOX_TOKEN_SECRET=
PROXMOX_TEMPLATE=local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst
PROXMOX_STORAGE=local-lvm
PROXMOX_BRIDGE=vmbr0
PROXMOX_VERIFY_TLS=false

# ── AWS S3 (Exportação Parquet / Data Lake) ────────────────────────
# O upload Parquet usa boto3 — credenciais via variáveis padrão AWS abaixo.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=vaultdb-backups
